# ─── API Keys (set at least one) ─────────────────────────────────
ANTHROPIC_API_KEY=your-key-here
OPENAI_API_KEY=your-key-here

# ─── Provider Selection ─────────────────────────────────────────
# HIVE_PROVIDER controls which model ladder to use.
# Options: openai (default), anthropic, ollama, ollama-tiered
HIVE_PROVIDER=openai

# ─── Model Override (optional) ──────────────────────────────────
# Force ALL personas to use a single model, bypassing tier routing:
# HIVE_MODEL=gpt-4o
# HIVE_MODEL=anthropic/claude-sonnet-4-6
# HIVE_MODEL=ollama/qwen3.5:4b

# ─── Logging ────────────────────────────────────────────────────
LITELLM_LOG=ERROR

# ─── Default Tier Routing ───────────────────────────────────────
# openai:         Tier 1 = gpt-4o-mini, Tier 2 = gpt-4o, Tier 3 = gpt-4o
# anthropic:      Tier 1 = haiku-4.5,   Tier 2 = sonnet-4.6, Tier 3 = opus-4.6
# ollama:         Tier 1-3 = qwen3.5:4b (single model, <= 8GB RAM)
# ollama-tiered:  Tier 1 = qwen3.5:2b, Tier 2 = qwen3.5:4b, Tier 3 = qwen3.5:9b (16GB+ RAM)
